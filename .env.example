# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── JWT AUTH ───────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-also-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SUPABASE (database + storage) ─────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Direct Postgres connection (for migrations)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ─── ANTHROPIC AI ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# AI model settings
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1500
AI_CONFIDENCE_THRESHOLD=70

# ─── STRIPE ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price IDs (create these in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_starter_monthly_id
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id

# ─── REDIS (task queue) ──────────────────────────────────────────────────────
# Railway provides this automatically — or use Upstash for free tier
# Format: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Panalo.ai <hello@panalo.ai>

# ─── CORS ORIGINS ────────────────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://panalo.ai,https://www.panalo.ai

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
